# Handle line endings automatically for text files
* text=auto

# Force shell scripts to always use LF (Unix) line endings
# This prevents the "invalid option name" errors in GitHub Actions
scripts/*.sh text eol=lf
*.sh text eol=lf

# Ensure other technical files stay consistent
*.py text eol=lf
*.lua text eol=lf
*.tex text eol=lf
requirements.txt text eol=lf

# Denote binary files (so Git doesn't try to fix their "line endings")
*.png binary
*.jpg binary
*.jar binary